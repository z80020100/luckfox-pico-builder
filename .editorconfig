root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 4

[Dockerfile]
indent_style = space
indent_size = 4

[**/Dockerfile]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab
